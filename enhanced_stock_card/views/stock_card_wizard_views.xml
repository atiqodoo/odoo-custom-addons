<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View with DEBUG features -->
    <record id="view_stock_card_wizard_form" model="ir.ui.view">
        <field name="name">stock.card.wizard.form</field>
        <field name="model">stock.card.wizard</field>
        <field name="arch" type="xml">
            <form string="Stock Card Report">
                <!-- DEBUG: Show notification banner -->
                <div class="alert alert-info" role="alert" style="margin-bottom: 10px;">
                    <strong>Product Search (ALL TYPES):</strong> Click the Products field below and start typing. 
                    This report now accepts all product types (storable, consumable, service).
                    If no products appear, click the "Debug Test" button.
                </div>
                
                <group>
                    <group string="Product Selection">
                        <!-- DEBUG: Multiple widget options to test -->
                        <field name="product_ids" 
                               widget="many2many_tags"
                               placeholder="Type product name or code here..."
                               options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True}"
                               context="{'tree_view_ref': 'product.product_product_tree_view', 'search_default_filter_to_sell': 1}"/>
                        <label for="product_count_available" string="Available Products:"/>
                        <div>
                            <field name="product_count_available" readonly="1" class="oe_inline"/>
                            <span class="oe_inline"> products in system (all types)</span>
                        </div>
                    </group>
                    <group string="Location Selection">
                        <field name="warehouse_id" options="{'no_create': True}"/>
                        <field name="location_ids" widget="many2many_tags" 
                               options="{'no_create': True}"/>
                    </group>
                </group>
                <group>
                    <group string="Date Range">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Options">
                        <field name="show_internal_transfers"/>
                        <field name="group_by_product"/>
                    </group>
                </group>
                
                <!-- DEBUG: Show debug information -->
                <group string="Debug Information" invisible="0">
                    <field name="debug_info" colspan="2" nolabel="1"/>
                </group>
                
                <group invisible="1">
                    <field name="excel_file" filename="excel_filename"/>
                    <field name="excel_filename" invisible="1"/>
                </group>
                
                <footer>
                    <button name="action_print_pdf" string="Print PDF" 
                            type="object" class="btn-primary"/>
                    <button name="action_export_excel" string="Export Excel" 
                            type="object" class="btn-secondary"/>
                    <button name="action_debug_test" string="🔍 Debug Test" 
                            type="object" class="btn-warning"
                            help="Run diagnostic tests"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_stock_card_wizard" model="ir.actions.act_window">
        <field name="name">Stock Card Report</field>
        <field name="res_model">stock.card.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_stock_card_wizard"/>
    </record>
</odoo>
