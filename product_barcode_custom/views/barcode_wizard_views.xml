<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_barcode_wizard_form" model="ir.ui.view">
        <field name="name">product.barcode.wizard.form</field>
        <field name="model">product.barcode.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Barcodes">
                <group>
                    <field name="mode"/>
                    <field name="product_ids" invisible="[('mode', '=', 'all')]"/>
                </group>
                <footer>
                    <button name="action_generate_barcodes" string="Generate" type="object" class="oe_highlight"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>