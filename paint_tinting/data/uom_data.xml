<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Custom Volume UoMs based on existing Litre (uom.product_uom_litre) -->
        <!-- Note: Litre already exists as the reference unit in Odoo -->
        
        <!-- 1 Litre UoM (using existing Litre as base) -->
        <record id="product_uom_litre_1" model="uom.uom">
            <field name="name">1L</field>
            <field name="category_id" ref="uom.product_uom_categ_vol"/>
            <field name="factor" eval="1.0"/>
            <field name="factor_inv" eval="1.0"/>
            <field name="uom_type">bigger</field>
            <field name="rounding" eval="0.0001"/>
        </record>

        <!-- 4 Litre UoM -->
        <record id="product_uom_litre_4" model="uom.uom">
            <field name="name">4L</field>
            <field name="category_id" ref="uom.product_uom_categ_vol"/>
            <field name="factor" eval="0.25"/>
            <field name="factor_inv" eval="4.0"/>
            <field name="uom_type">bigger</field>
            <field name="rounding" eval="0.0001"/>
        </record>

        <!-- 20 Litre UoM -->
        <record id="product_uom_litre_20" model="uom.uom">
            <field name="name">20L</field>
            <field name="category_id" ref="uom.product_uom_categ_vol"/>
            <field name="factor" eval="0.05"/>
            <field name="factor_inv" eval="20.0"/>
            <field name="uom_type">bigger</field>
            <field name="rounding" eval="0.0001"/>
        </record>
    </data>
</odoo>