<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Colorant Mapping Wizard Form View -->
    <record id="view_colorant_mapping_wizard_form" model="ir.ui.view">
        <field name="name">colorant.mapping.wizard.form</field>
        <field name="model">colorant.mapping.wizard</field>
        <field name="arch" type="xml">
            <form string="Map Existing Products as Colorants">
                <header>
                    <button name="action_map_colorants" string="Map Colorants" 
                            type="object" class="oe_highlight"/>
                    <button string="Cancel" special="cancel"/>
                </header>
                
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <h4>Map Your Existing Products as Colorants</h4>
                        <p>
                            Select existing products from your inventory for each colorant code (C1-C16).
                            The selected products will be marked as colorants and their UoM will be set to Litre.
                        </p>
                    </div>
                    
                    <group>
                        <field name="mapping_line_ids" nolabel="1">
                            <list editable="bottom" create="0" delete="0">
                                <field name="colorant_code" readonly="1"/>
                                <field name="product_id" 
                                       options="{'no_create': True}"
                                       placeholder="Select product..."/>
                                <field name="product_name" readonly="1" optional="show"/>
                                <field name="current_uom" readonly="1" optional="show"/>
                            </list>
                        </field>
                    </group>
                    
                    <div class="alert alert-warning mt-3" role="alert">
                        <strong>Note:</strong> The Unit of Measure (UoM) of selected products will be changed to <strong>Litre</strong> 
                        to ensure proper colorant volume calculations.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Colorant Mapping Wizard Action -->
    <record id="action_colorant_mapping_wizard" model="ir.actions.act_window">
        <field name="name">Map Existing Products as Colorants</field>
        <field name="res_model">colorant.mapping.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>
</odoo>