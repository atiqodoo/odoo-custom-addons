<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Courier Dispatch Sequence -->
        <record id="seq_courier_dispatch" model="ir.sequence">
            <field name="name">Courier Dispatch</field>
            <field name="code">courier.dispatch</field>
            <field name="prefix">COURIER/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
