<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Register Courier Dispatch Wizard Form View -->
    <record id="view_register_courier_dispatch_wizard_form" model="ir.ui.view">
        <field name="name">register.courier.dispatch.wizard.form</field>
        <field name="model">register.courier.dispatch.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Courier Dispatch">
                <sheet>
                    <group>
                        <group string="Order Information">
                            <field name="pos_order_id" readonly="1"/>
                            <field name="customer_id" 
                                   options="{'no_open': True, 'no_create_edit': False}"
                                   placeholder="Select or create customer..."/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Courier Information" name="courier_info">
                            <field name="courier_company_id" placeholder="Select courier company (optional)..."/>
                            <field name="courier_name" required="1" placeholder="Courier name..."/>
                            <field name="courier_phone" required="1" placeholder="+254 XXX XXX XXX"/>
                            <field name="courier_reference" placeholder="Tracking/Reference number..."/>
                            <field name="vehicle_plate" placeholder="Vehicle registration..."/>
                        </group>
                        
                        <group string="Payment Details" name="payment_info">
                            <field name="courier_payment_responsible" widget="radio"/>
                            <field name="courier_fee" 
                                   invisible="courier_payment_responsible == 'customer'" 
                                   required="courier_payment_responsible in ('company', 'shared')"/>
                            <field name="payment_journal_id" 
                                   invisible="courier_payment_responsible == 'customer'" 
                                   required="courier_payment_responsible in ('company', 'shared')" 
                                   placeholder="Select payment journal..."/>
                        </group>
                    </group>
                    
                    <group string="Delivery Address">
                        <field name="use_customer_address" widget="boolean_toggle"/>
                        <field name="delivery_street" placeholder="Street..." readonly="use_customer_address"/>
                        <field name="delivery_street2" placeholder="Street 2..." readonly="use_customer_address"/>
                        <field name="delivery_city" placeholder="City..." readonly="use_customer_address"/>
                        <field name="delivery_state_id" placeholder="State..." readonly="use_customer_address"/>
                        <field name="delivery_zip" placeholder="ZIP..." readonly="use_customer_address"/>
                        <field name="delivery_country_id" placeholder="Country..." readonly="use_customer_address"/>
                    </group>
                    
                    <notebook>
                        <page string="Items to Dispatch" name="items">
                            <field name="line_ids">
                                <list editable="bottom" string="Dispatch Items">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" readonly="1"/>
                                    <field name="ordered_qty" readonly="1" string="Original Qty"/>
                                    <field name="remaining_qty" readonly="1" string="Available Qty" 
                                           decoration-info="remaining_qty &gt; 0"
                                           decoration-warning="remaining_qty &lt; ordered_qty"/>
                                    <field name="dispatch_qty" required="1" string="Qty to Dispatch"/>
                                    <field name="price_unit" readonly="1"/>
                                    <field name="subtotal" readonly="1" sum="Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_quantity" string="Total Quantity"/>
                                <field name="total_value" string="Total Value" widget="monetary"/>
                            </group>
                        </page>
                        
                        <page string="Documentation" name="documentation">
                            <group>
                                <field name="delivery_instructions" placeholder="Special delivery instructions..."/>
                                <field name="notes" placeholder="Additional notes..."/>
                            </group>
                            <separator string="Attachments"/>
                            <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                
                <footer>
                    <button name="action_confirm" 
                            string="Register Dispatch" 
                            type="object" 
                            class="btn-primary" 
                            data-hotkey="q"/>
                    <button string="Cancel" 
                            class="btn-secondary" 
                            special="cancel" 
                            data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
