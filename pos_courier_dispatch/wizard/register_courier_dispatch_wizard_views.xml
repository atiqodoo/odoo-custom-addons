<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Register Courier Dispatch Wizard Form -->
    <record id="view_register_courier_dispatch_wizard_form" model="ir.ui.view">
        <field name="name">register.courier.dispatch.wizard.form</field>
        <field name="model">register.courier.dispatch.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Courier Dispatch">
                <sheet>
                    <group>
                        <group string="Order Information">
                            <field name="pos_order_id" readonly="1"/>
                            <field name="customer_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Courier Details">
                            <field name="courier_company_id"/>
                            <field name="courier_name"/>
                            <field name="courier_phone"/>
                            <field name="courier_reference"/>
                            <field name="vehicle_plate"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Payment Information">
                            <field name="courier_payment_responsible"/>
                            <field name="courier_fee_vat_inclusive" invisible="courier_payment_responsible == 'customer'"/>
                            <field name="vat_rate" invisible="courier_payment_responsible == 'customer'" readonly="1" widget="percentage"/>
                            <field name="courier_fee" widget="monetary"/>
                            
                            <!-- VAT Breakdown -->
                            <label for="courier_fee_net" string="Fee Breakdown" invisible="courier_payment_responsible == 'customer'"/>
                            <div invisible="courier_payment_responsible == 'customer'" class="o_row">
                                <span class="text-muted">Net: </span>
                                <field name="courier_fee_net" readonly="1" widget="monetary" class="oe_inline"/>
                                <span class="text-muted ms-3">VAT: </span>
                                <field name="courier_fee_vat" readonly="1" widget="monetary" class="oe_inline"/>
                            </div>
                            
                            <field name="payment_journal_id" 
                                   invisible="courier_payment_responsible == 'customer'"
                                   required="courier_payment_responsible in ('company', 'shared')"/>
                        </group>
                        <group string="Delivery Address">
                            <field name="use_customer_address"/>
                            <field name="delivery_street"/>
                            <field name="delivery_street2"/>
                            <field name="delivery_city"/>
                            <field name="delivery_state_id"/>
                            <field name="delivery_zip"/>
                            <field name="delivery_country_id"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Items to Dispatch" name="items">
                            <field name="line_ids">
                                <list editable="bottom" string="Dispatch Lines">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" readonly="1"/>
                                    <field name="ordered_qty" readonly="1"/>
                                    <field name="remaining_qty" readonly="1"/>
                                    <field name="dispatch_qty"/>
                                    <field name="price_unit" readonly="1"/>
                                    <field name="subtotal" readonly="1" sum="Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="pos_order_line_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_quantity" string="Total Quantity"/>
                                <field name="total_value" string="Total Value" widget="monetary"/>
                            </group>
                        </page>
                        <page string="Additional Information" name="additional_info">
                            <group>
                                <field name="delivery_instructions"/>
                                <field name="notes"/>
                            </group>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="Create Dispatch" name="action_confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>