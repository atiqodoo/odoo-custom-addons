<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Extend Settings View -->
    <record id="res_config_settings_view_form_inherit_courier" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.courier</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <h2>Courier Dispatch</h2>
                <div class="row mt16 o_settings_container">
                    
                    <!-- Accounting Configuration -->
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <label for="courier_cogs_account_id" string="Courier Dispatch Accounting"/>
                            <div class="text-muted">
                                Configure accounting for courier fees paid by company
                            </div>
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="courier_cogs_account_id" string="Courier COGS Account" class="col-lg-4 o_light_label"/>
                                    <field name="courier_cogs_account_id" 
                                           class="oe_inline" 
                                           placeholder="Net expense account..."
                                           options="{'no_create': True, 'no_open': True}"/>
                                </div>
                                <div class="row">
                                    <label for="courier_vat_account_id" string="VAT Input Account" class="col-lg-4 o_light_label"/>
                                    <field name="courier_vat_account_id" 
                                           class="oe_inline" 
                                           placeholder="Claimable VAT account..."
                                           options="{'no_create': True, 'no_open': True}"/>
                                </div>
                                <div class="row">
                                    <label for="default_courier_journal_id" string="Default Payment Journal" class="col-lg-4 o_light_label"/>
                                    <field name="default_courier_journal_id" 
                                           class="oe_inline" 
                                           placeholder="Select payment journal..."
                                           options="{'no_create': True, 'no_open': True}"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- VAT Configuration -->
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <label for="courier_vat_rate" string="Courier VAT Settings"/>
                            <div class="text-muted">
                                Configure VAT calculation for courier fees
                            </div>
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="courier_vat_rate" string="VAT Rate" class="col-lg-4 o_light_label"/>
                                    <field name="courier_vat_rate" 
                                           class="oe_inline" 
                                           widget="percentage"/>
                                </div>
                                <div class="row">
                                    <label for="courier_fee_vat_inclusive" class="col-lg-4 o_light_label"/>
                                    <field name="courier_fee_vat_inclusive" class="oe_inline"/>
                                    <span class="text-muted ms-2">
                                        Courier fees include VAT
                                    </span>
                                </div>
                                
                                <!-- VAT Explanation -->
                                <div class="alert alert-info mt-3" role="alert">
                                    <strong>VAT Accounting:</strong><br/>
                                    When company pays courier fees, the journal entry will be:
                                    <ul class="mb-0 mt-2">
                                        <li><strong>Debit:</strong> Courier COGS Account (net amount)</li>
                                        <li><strong>Debit:</strong> VAT Input Account (VAT amount)</li>
                                        <li><strong>Credit:</strong> Payment Journal (total amount)</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </xpath>
        </field>
    </record>

</odoo>