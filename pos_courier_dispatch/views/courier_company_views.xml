<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Courier Company Form View -->
    <record id="view_courier_company_form" model="ir.ui.view">
        <field name="name">courier.company.form</field>
        <field name="model">courier.company</field>
        <field name="arch" type="xml">
            <form string="Courier Company">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_dispatches" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-truck" 
                                invisible="dispatch_count == 0">
                            <field name="dispatch_count" widget="statinfo" string="Dispatches"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" string="Courier Company Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. DHL Express, FedEx, Local Courier..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Contact Information">
                            <field name="active" invisible="1"/>
                            <field name="partner_id"/>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="email" widget="email"/>
                            <field name="website" widget="url"/>
                        </group>
                        <group string="Configuration">
                            <field name="default_journal_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Any additional information about this courier company..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Courier Company List View -->
    <record id="view_courier_company_list" model="ir.ui.view">
        <field name="name">courier.company.list</field>
        <field name="model">courier.company</field>
        <field name="arch" type="xml">
            <list string="Courier Companies">
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="dispatch_count"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Courier Company Search View -->
    <record id="view_courier_company_search" model="ir.ui.view">
        <field name="name">courier.company.search</field>
        <field name="model">courier.company</field>
        <field name="arch" type="xml">
            <search string="Search Courier Companies">
                <field name="name" string="Company"/>
                <field name="phone" string="Phone"/>
                <field name="email" string="Email"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Active Status" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: Courier Companies -->
    <record id="action_courier_company" model="ir.actions.act_window">
        <field name="name">Courier Companies</field>
        <field name="res_model">courier.company</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_courier_company_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a courier company!
            </p>
            <p>
                Courier companies are used to quickly fill courier details when creating dispatches.
            </p>
        </field>
    </record>

</odoo>
