<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_order_line_form_inherit_fixed_discount" model="ir.ui.view">
        <field name="name">pos.order.line.form.fixed.discount</field>
        <field name="model">pos.order.line</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_line_form"/>
        <field name="arch" type="xml">
            <field name="discount" position="after">
                <field name="discount_fixed"/>
            </field>
        </field>
    </record>

    <record id="view_pos_order_form_inherit_fixed_discount" model="ir.ui.view">
        <field name="name">pos.order.form.fixed.discount</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lines']/list/field[@name='discount']" position="after">
                <field name="discount_fixed" string="Fixed Disc"/>
            </xpath>
        </field>
    </record>
</odoo>
