<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         Product Template — Non-Returnable Flag
         Adds the "Not Returnable in POS" checkbox to the product form
         under the Point of Sale tab.
         ================================================================ -->

    <record id="view_product_template_pos_not_returnable" model="ir.ui.view">
        <field name="name">product.template.pos.not.returnable</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="point_of_sale.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Inject inside the "Point of Sale" page, after the pos group -->
            <xpath expr="//page[@name='pos']//group[@name='pos']" position="after">
                <group string="Returns" name="pos_return_settings">
                    <field
                        name="pos_not_returnable"
                        string="Not Returnable in POS"
                        widget="boolean_toggle"
                        help="When enabled, cashiers cannot select this product for a POS return or refund.  Typical use: tinted paints, custom-cut materials, service fees."
                    />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
