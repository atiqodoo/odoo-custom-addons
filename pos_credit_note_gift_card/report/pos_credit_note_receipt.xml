<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        pos_credit_note_receipt.xml
        ===========================
        Server-side QWeb report for the POS Credit Note Gift Card.

        This report is registered on ``loyalty.card`` (same as the standard
        Odoo gift-card print report) and is assigned to the gift-card
        loyalty program as ``pos_report_print_id``.

        The cashier can print it:
          a) From the POS payment screen via the thermal printer using
             the OWL component (credit_note_receipt.xml in static/src/xml).
          b) From the back-office loyalty.card form view.

        Layout mimics a standard 80 mm thermal POS receipt.
        No A4 formatting, no invoice grid — just a compact thermal layout.
    -->

    <report
        id="action_report_pos_credit_note_receipt"
        name="pos_credit_note_gift_card.report_pos_credit_note_receipt"
        model="loyalty.card"
        report_type="qweb-html"
        string="Credit Note Receipt"
        print_report_name="'Credit_Note_' + object.code"
        attachment_use="False"
        groups="point_of_sale.group_pos_user"
    />

    <template id="report_pos_credit_note_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="card">
                <div class="pos-receipt pos-credit-note-receipt" style="width:72mm; font-family: monospace; font-size: 11px; padding: 4px;">

                    <!-- ── Header ─────────────────────────────────────── -->
                    <div style="text-align:center; margin-bottom:4px;">
                        <strong style="font-size:14px;">
                            <t t-esc="card.program_id.company_id.name or 'POS'"/>
                        </strong>
                        <br/>
                        <t t-if="card.program_id.company_id.street">
                            <t t-esc="card.program_id.company_id.street"/>
                            <br/>
                        </t>
                        <t t-if="card.program_id.company_id.city">
                            <t t-esc="card.program_id.company_id.city"/>
                            <br/>
                        </t>
                        <t t-if="card.program_id.company_id.phone">
                            Tel: <t t-esc="card.program_id.company_id.phone"/>
                            <br/>
                        </t>
                    </div>

                    <div style="text-align:center; border-top:1px dashed #000; border-bottom:1px dashed #000; padding:3px 0; margin-bottom:4px;">
                        <strong style="font-size:13px; letter-spacing:2px;">*** CREDIT NOTE ***</strong>
                    </div>

                    <!-- ── Card Details ──────────────────────────────── -->
                    <table style="width:100%; border-collapse:collapse;">
                        <tr>
                            <td style="width:50%;">Program:</td>
                            <td style="text-align:right; font-weight:bold;">
                                <t t-esc="card.program_id.name or ''"/>
                            </td>
                        </tr>
                        <tr>
                            <td>Date:</td>
                            <td style="text-align:right;">
                                <t t-esc="card.create_date.strftime('%d/%m/%Y %H:%M') if card.create_date else ''"/>
                            </td>
                        </tr>
                        <t t-if="card.partner_id">
                            <tr>
                                <td>Customer:</td>
                                <td style="text-align:right;">
                                    <t t-esc="card.partner_id.name"/>
                                </td>
                            </tr>
                        </t>
                    </table>

                    <div style="border-top:1px dashed #000; margin:4px 0;"/>

                    <!-- ── Gift Card Code ────────────────────────────── -->
                    <div style="text-align:center; margin:6px 0;">
                        <div style="font-size:10px; margin-bottom:2px;">Gift Card Code:</div>
                        <div style="font-size:16px; font-weight:bold; letter-spacing:3px; border:1px solid #000; padding:4px 8px; display:inline-block;">
                            <t t-esc="card.code or ''"/>
                        </div>
                    </div>

                    <!-- ── Balance ───────────────────────────────────── -->
                    <div style="border-top:1px dashed #000; margin:4px 0;"/>
                    <table style="width:100%;">
                        <tr>
                            <td style="font-size:13px; font-weight:bold;">CREDIT BALANCE:</td>
                            <td style="text-align:right; font-size:15px; font-weight:bold;">
                                <t t-esc="'{:,.2f}'.format(card.points or 0.0)"/>
                                <t t-if="card.program_id.company_id.currency_id">
                                    &#160;<t t-esc="card.program_id.company_id.currency_id.symbol"/>
                                </t>
                            </td>
                        </tr>
                    </table>

                    <div style="border-top:1px dashed #000; margin:4px 0;"/>

                    <!-- ── Instructions ──────────────────────────────── -->
                    <div style="text-align:center; font-size:10px; margin-top:4px;">
                        Present this code at the checkout to redeem your credit.
                        <br/>
                        Gift card balance does not expire.
                    </div>

                    <!-- ── Footer ────────────────────────────────────── -->
                    <div style="text-align:center; border-top:1px dashed #000; margin-top:6px; padding-top:4px; font-size:9px; color:#555;">
                        Thank you for your business.
                    </div>

                </div>
            </t>
        </t>
    </template>
</odoo>
