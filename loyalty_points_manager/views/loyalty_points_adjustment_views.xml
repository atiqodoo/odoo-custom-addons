<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_loyalty_points_adjustment_list" model="ir.ui.view">
        <field name="name">loyalty.points.adjustment.list</field>
        <field name="model">loyalty.points.adjustment</field>
        <field name="arch" type="xml">
            <list string="Loyalty Points Adjustments"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'"
                  decoration-info="state == 'draft'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="operation_type"/>
                <field name="points_amount"/>
                <field name="balance_before"/>
                <field name="balance_after"/>
                <field name="user_id"/>
                <field name="create_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-muted="state == 'cancelled'"
                       decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_loyalty_points_adjustment_form" model="ir.ui.view">
        <field name="name">loyalty.points.adjustment.form</field>
        <field name="model">loyalty.points.adjustment</field>
        <field name="arch" type="xml">
            <form string="Loyalty Points Adjustment">
                <header>
                    <button name="action_confirm" 
                            string="Confirm" 
                            type="object" 
                            class="oe_highlight"
                            invisible="state != 'draft'"
                            data-hotkey="q"/>
                    <button name="action_cancel" 
                            string="Cancel" 
                            type="object"
                            invisible="state == 'cancelled'"
                            data-hotkey="x"/>
                    <button name="action_draft" 
                            string="Reset to Draft" 
                            type="object"
                            invisible="state != 'cancelled'"
                            data-hotkey="r"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(account.action_move_journal_line)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-book"
                                invisible="not account_move_id"
                                context="{'search_default_move_id': account_move_id}">
                            <span class="o_stat_text">Journal Entry</span>
                        </button>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Customer Information">
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="operation_type" 
                                   widget="radio" 
                                   readonly="state != 'draft'"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Points Information">
                            <field name="points_amount" readonly="state != 'draft'"/>
                            <field name="balance_before" widget="float"/>
                            <field name="balance_after" 
                                   widget="float"
                                   decoration-success="balance_after >= balance_before and operation_type == 'add'"
                                   decoration-warning="balance_after &lt; balance_before and operation_type == 'reduce'"/>
                        </group>
                    </group>
                    
                    <group string="Reason">
                        <field name="reason" 
                               placeholder="Reason for adjustment..."
                               nolabel="1"
                               readonly="state != 'draft'"/>
                    </group>
                    
                    <notebook>
                        <page string="Accounting" name="accounting">
                            <group>
                                <group>
                                    <field name="company_id" readonly="1"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="journal_id" readonly="state != 'draft'"/>
                                    <field name="account_move_id" readonly="1"/>
                                </group>
                                <group>
                                    <field name="debit_account_id" readonly="state != 'draft'"/>
                                    <field name="credit_account_id" readonly="state != 'draft'"/>
                                    <field name="points_value" 
                                           widget="monetary" 
                                           readonly="state != 'draft'"/>
                                </group>
                            </group>
                            <group>
                                <div class="alert alert-info" role="alert" invisible="state != 'draft'">
                                    <p><strong>Accounting Integration Guidelines:</strong></p>
                                    <ul>
                                        <li>Fill all accounting fields to create a journal entry</li>
                                        <li><strong>Add Points:</strong> DR Loyalty Expense → CR Loyalty Liability</li>
                                        <li><strong>Reduce Points:</strong> DR Loyalty Liability → CR Loyalty Expense</li>
                                        <li>The journal entry will be posted automatically upon confirmation</li>
                                    </ul>
                                </div>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_loyalty_points_adjustment_search" model="ir.ui.view">
        <field name="name">loyalty.points.adjustment.search</field>
        <field name="model">loyalty.points.adjustment</field>
        <field name="arch" type="xml">
            <search string="Search Adjustments">
                <field name="name" string="Reference"/>
                <field name="partner_id" string="Customer"/>
                <field name="user_id" string="Responsible"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Add Points" name="add" domain="[('operation_type', '=', 'add')]"/>
                <filter string="Reduce Points" name="reduce" domain="[('operation_type', '=', 'reduce')]"/>
                <separator/>
                <filter string="My Adjustments" name="my_adjustments" 
                        domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Creation Date" name="creation_date" date="create_date"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Operation Type" name="group_operation" context="{'group_by': 'operation_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Responsible" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Creation Date" name="group_create_date" context="{'group_by': 'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_loyalty_points_adjustment" model="ir.actions.act_window">
        <field name="name">Loyalty Points Adjustments</field>
        <field name="res_model">loyalty.points.adjustment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first loyalty points adjustment
            </p>
            <p>
                Use this feature to manually add or reduce customer loyalty points.
                All adjustments are tracked with full audit trail and accounting integration.
            </p>
        </field>
    </record>

    <!-- Root Menu under Sales -->
    <menuitem id="menu_loyalty_points_root"
              name="Loyalty Points"
              parent="sale.sale_menu_root"
              sequence="50"/>

    <!-- Menu Items -->
    <menuitem id="menu_loyalty_points_adjustment"
              name="Points Adjustments"
              parent="menu_loyalty_points_root"
              action="action_loyalty_points_adjustment"
              sequence="20"/>

    <!-- Configuration Menu -->
    <menuitem id="menu_loyalty_points_config"
              name="Configuration"
              parent="menu_loyalty_points_root"
              sequence="100"/>

    <!-- Sequence -->
    <record id="seq_loyalty_points_adjustment" model="ir.sequence">
        <field name="name">Loyalty Points Adjustment</field>
        <field name="code">loyalty.points.adjustment</field>
        <field name="prefix">LPA/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
    </record>

</odoo>
