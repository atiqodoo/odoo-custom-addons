<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Collect Pending Items Wizard Form -->
    <record id="view_collect_pending_items_wizard_form" model="ir.ui.view">
        <field name="name">collect.pending.items.wizard.form</field>
        <field name="model">collect.pending.items.wizard</field>
        <field name="arch" type="xml">
            <form string="Collect Pending Items">
                <group>
                    <group>
                        <field name="pending_collection_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="collection_date"/>
                    </group>
                </group>
                
                <group string="Items to Collect">
                    <p class="text-muted">
                        Specify how much of each item the customer is collecting now.
                    </p>
                </group>
                
                <field name="line_ids">
                    <list editable="bottom">
                        <field name="collection_line_id" column_invisible="1"/>
                        <field name="sequence" widget="handle"/>
                        <field name="product_id" readonly="1"/>
                        <field name="tint_color_code" readonly="1" 
                               optional="show"/>
                        <field name="pending_qty" readonly="1" 
                               string="Still Pending"/>
                        <field name="collect_qty" string="Collect Now"/>
                        <field name="product_uom_id" readonly="1"/>
                    </list>
                </field>
                
                <group>
                    <field name="notes" placeholder="Collection notes..."/>
                </group>
                
                <footer>
                    <button string="Confirm Collection" name="action_confirm" 
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
</odoo>
