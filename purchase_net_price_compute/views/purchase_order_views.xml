<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_inherit_netprice" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.netprice</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- Add net_price field to order lines tree view -->
            <xpath expr="//field[@name='order_line']//field[@name='price_unit']" position="after">
                <field name="net_price" optional="show" readonly="1"/>
                <field name="applied_discount" optional="hide" readonly="1"/>
                <field name="applied_freight" optional="hide" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>