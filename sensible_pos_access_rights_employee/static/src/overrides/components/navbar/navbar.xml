<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="sensible_pos_access_rights_employee.Navbar" t-inherit="point_of_sale.Navbar" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-burger-menu-items')]" position="before">
            <t t-set="currentEmployee" t-value="pos.get_cashier()"/>
        </xpath>
        <!-- Hide Install App menu -->
        <xpath expr="//DropdownItem[@t-if='!isDisplayStandalone']" position="attributes">
            <attribute name="t-if">!isDisplayStandalone</attribute>
            <attribute name="onSelected">() =&gt; pos.sblGuardedAction('install_app', () =&gt; window.open(this.appUrl), { label: 'Install App' })</attribute>
        </xpath>
        <!-- Hide Orders menu -->
        <xpath expr="//DropdownItem[@onSelected=&quot;() =&gt; this.pos.showScreen('TicketScreen')&quot;]" position="attributes">
            <attribute name="t-if">true</attribute>
            <attribute name="onSelected">() =&gt; pos.sblGuardedAction('orders_menu', () =&gt; this.pos.showScreen('TicketScreen'), { label: 'Orders' })</attribute>
        </xpath>
        <!-- Hide Cash In/Out menu -->
        <xpath expr="//DropdownItem[@t-if='showCashMoveButton']" position="attributes">
            <attribute name="t-if">showCashMoveButton</attribute>
        </xpath>
        <!-- Hide Backend menu -->
        <xpath expr="//DropdownItem[@onSelected='() =&gt; pos.closePos()']" position="attributes">
            <attribute name="t-if">true</attribute>
        </xpath>
        <!-- Hide Close Register menu -->
        <xpath expr="//DropdownItem[@onSelected='() =&gt; this.pos.closeSession()']" position="attributes">
            <attribute name="t-if">true</attribute>
        </xpath>
        <!-- Hide Clear Cache menu -->
        <xpath expr="//DropdownItem[@onSelected='() =&gt; this.clearCache()']" position="attributes">
            <attribute name="t-if">this.env.debug</attribute>
            <attribute name="onSelected">() =&gt; pos.sblGuardedAction('clear_cache', () =&gt; this.clearCache(), { label: 'Clear Cache' })</attribute>
        </xpath>
        <!-- Hide Debug Window menu -->
        <xpath expr="//DropdownItem[@onSelected='() =&gt; debug.toggleWidget()']" position="attributes">
            <attribute name="t-if">this.env.debug</attribute>
            <attribute name="onSelected">() =&gt; pos.sblGuardedAction('debug_window', () =&gt; debug.toggleWidget(), { label: 'Debug Window' })</attribute>
        </xpath>
    </t>
</templates>
