<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="sensible_pos_access_rights_employee.PartnerLine" t-inherit="point_of_sale.PartnerLine" t-inherit-mode="extension">
        <!-- Hide Edit Details in mobile view -->
        <xpath expr="//t[@t-if='ui.isSmall']//DropdownItem[@onSelected='() =&gt; props.onClickEdit(props.partner)']" position="attributes">
            <attribute name="t-if">!this.pos.get_cashier()?.sbl_hide_pos_edit_customer_button</attribute>
        </xpath>
        <!-- Hide Edit Details in desktop view -->
        <xpath expr="//t[@t-else='']//DropdownItem[@onSelected='() =&gt; props.onClickEdit(props.partner)']" position="attributes">
            <attribute name="t-if">!this.pos.get_cashier()?.sbl_hide_pos_edit_customer_button</attribute>
        </xpath>
    </t>
</templates>
