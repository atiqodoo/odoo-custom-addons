<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="sensible_pos_access_rights_employee.ActionpadWidget" t-inherit="point_of_sale.ActionpadWidget" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('actionpad')]" position="before">
            <t t-set="currentEmployee" t-value="pos.get_cashier()"/>
        </xpath>
        <xpath expr="//div[hasclass('validation')]//button[hasclass('pay-order-button')]" position="attributes">
            <attribute name="t-if">true</attribute>
        </xpath>
        <xpath expr="//button[hasclass('mobile-more-button')]" position="attributes">
            <attribute name="t-if">true</attribute>
        </xpath>
        <xpath expr="//SelectPartnerButton" position="attributes">
            <attribute name="t-if">true</attribute>
        </xpath>
    </t>
</templates>
