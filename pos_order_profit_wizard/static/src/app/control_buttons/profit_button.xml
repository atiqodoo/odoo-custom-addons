<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_order_profit_wizard.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('more-btn')]" position="before">
            <button t-if="!props.showRemainingButtons and !ui.isSmall"
                t-att-class="this.uiActionButtonClass || 'btn btn-light btn-lg lh-lg'"
                t-on-click="openProfitWizard">
                <i class="fa fa-line-chart me-1" role="img" aria-label="Order Profit" title="Order Profit"/>
                Profit
            </button>
        </xpath>
        <xpath expr="//t[@t-if='props.showRemainingButtons']/div" position="inside">
            <button class="btn btn-secondary btn-lg py-5" t-on-click="openProfitWizard">
                <i class="fa fa-line-chart me-1" role="img" aria-label="Order Profit" title="Order Profit"/>
                Profit
            </button>
        </xpath>
    </t>
</templates>
