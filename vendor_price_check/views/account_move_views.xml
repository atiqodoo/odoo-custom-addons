<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================= -->
    <!-- 1. Your Existing Buttons (Unchanged)          -->
    <!-- ============================================= -->
    <record id="view_move_form_inherit_vendor_price_check" model="ir.ui.view">
        <field name="name">account.move.form.inherit.vendor.price.check</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']" position="after">
                <field name="discrepancy_count" readonly="1"/>
                <field name="discrepancy_approved" readonly="1"/>
                <button name="action_view_discrepancies"
                        type="object"
                        string="View Discrepancies"
                        invisible="discrepancy_count == 0"/>
                <button name="action_approve_discrepancy"
                        type="object"
                        string="Approve Discrepancies"
                        invisible="discrepancy_count == 0 or discrepancy_approved"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================= -->
    <!-- 2. NEW: Add column to invoice lines           -->
    <!-- ============================================= -->
    <record id="view_move_form_inherit_line_subtotal_incl_vat" model="ir.ui.view">
        <field name="name">account.move.form.inherit.line.subtotal.incl.vat</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list" position="inside">
                <field name="line_subtotal_incl_vat"
                       widget="monetary"
                       options="{'currency_field': 'currency_id'}"
                       sum="Total Incl. VAT"/>
            </xpath>
        </field>
    </record>

    <!-- Optional: Show in Bill List View -->
    <record id="view_move_tree_inherit_line_subtotal" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.line.subtotal</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <list>
                <field name="amount_total" string="Total"/>
            </list>
        </field>
    </record>

</odoo>