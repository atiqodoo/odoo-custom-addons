<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="pos_cod.CodLineDetailsDialog">
        <Dialog size="'lg'">
            <t t-set-slot="header">
                <div class="modal-header">
                    <h4 class="modal-title">
                        Order Items - <t t-esc="props.order.name"/>
                    </h4>
                    <button type="button" class="btn-close" t-on-click="onClose"/>
                </div>
            </t>

            <t t-if="state.loading">
                <div class="d-flex align-items-center justify-content-center p-4 gap-2">
                    <span class="spinner-border spinner-border-sm text-primary"/>
                    <span>Loading order lines...</span>
                </div>
            </t>
            <t t-elif="state.error">
                <div class="alert alert-danger m-3">
                    <i class="fa fa-exclamation-triangle me-2"/>
                    <t t-esc="state.error"/>
                </div>
            </t>
            <t t-elif="state.lines.length === 0">
                <div class="alert alert-warning m-3">No order lines found.</div>
            </t>
            <t t-else="">
                <table class="table table-sm table-bordered align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th class="text-end" style="width:90px">Qty</th>
                            <th class="text-end" style="width:110px">Returned</th>
                            <th class="text-end" style="width:110px">Remaining</th>
                            <th class="text-end" style="width:120px">Unit Price</th>
                            <th class="text-end" style="width:120px">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.lines" t-as="line" t-key="line.id">
                            <tr>
                                <td>
                                    <div class="fw-semibold"><t t-esc="productName(line)"/></div>
                                    <t t-if="line.discount">
                                        <small class="text-muted"><t t-esc="line.discount"/>% disc</small>
                                    </t>
                                </td>
                                <td class="text-end"><t t-esc="lineQty(line)"/></td>
                                <td class="text-end"><t t-esc="returnedQty(line)"/></td>
                                <td class="text-end"><t t-esc="remainingQty(line)"/></td>
                                <td class="text-end"><t t-esc="formatCurrency(line.price_unit)"/></td>
                                <td class="text-end fw-semibold">
                                    <t t-esc="formatCurrency(line.price_subtotal_incl)"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr class="table-secondary fw-bold fs-6">
                            <td colspan="5" class="text-end">Order Lines Total</td>
                            <td class="text-end">
                                <t t-esc="formatCurrency(orderTotal)"/>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </t>

            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="onClose">Close</button>
            </t>
        </Dialog>
    </t>
</templates>
