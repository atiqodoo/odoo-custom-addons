<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!--
        Inject COD button after the ControlButtons component in ProductScreen.

        Why //ControlButtons and not //div[hasclass('control-buttons')]:
        The parent div uses t-attf-class (dynamic), which hasclass() does not match.
        Targeting the ControlButtons component element works reliably.
        position="after" places the button as the next sibling inside the same div.
        The !ui.isSmall guard mirrors the one on ControlButtons so both hide together.
    -->
    <t t-name="pos_cod.ProductScreenCodButton"
       t-inherit="point_of_sale.ProductScreen"
       t-inherit-mode="extension">
        <xpath expr="//ControlButtons" position="after">
            <button t-if="codButtonVisible and !ui.isSmall"
                    class="btn btn-light btn-lg lh-lg cod-dispatch-button"
                    t-on-click="onCodButtonClick">
                <i class="fa fa-truck me-1" role="img" aria-label="COD" title="Cash on Delivery"/>
                COD
            </button>
        </xpath>
    </t>

</templates>
