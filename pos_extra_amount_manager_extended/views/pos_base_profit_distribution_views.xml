<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_pos_base_profit_distribution_list" model="ir.ui.view">
        <field name="name">pos.base.profit.distribution.list</field>
        <field name="model">pos.base.profit.distribution</field>
        <field name="arch" type="xml">
            <list string="Base Profit Distributions" create="false" delete="false">
                <field name="create_date"/>
                <field name="pos_order_id"/>
                <field name="distribution_amount" widget="monetary" sum="Total Distributed"/>
                <field name="percent"/>
                <field name="payment_journal_id"/>
                <field name="partner_id"/>
                <field name="state" 
                       widget="badge"
                       decoration-success="state == 'posted'"
                       decoration-info="state == 'draft'"
                       decoration-muted="state == 'cancelled'"/>
                <button name="action_view_journal_entries" 
                        type="object" 
                        string="View Entry" 
                        icon="fa-book"
                        invisible="state != 'posted'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_pos_base_profit_distribution_form" model="ir.ui.view">
        <field name="name">pos.base.profit.distribution.form</field>
        <field name="model">pos.base.profit.distribution</field>
        <field name="arch" type="xml">
            <form string="Base Profit Distribution" create="false" delete="false">
                <header>
                    <button name="action_view_journal_entries" 
                            string="View Journal Entry" 
                            type="object" 
                            class="btn-primary" 
                            invisible="state != 'posted'"/>
                    <field name="state" 
                           widget="statusbar" 
                           statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Reference">
                            <field name="pos_order_id" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                            <field name="create_uid" readonly="1"/>
                        </group>
                        <group string="Distribution">
                            <field name="distribution_amount" widget="monetary" readonly="1"/>
                            <field name="percent" readonly="1"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Payment">
                            <field name="payment_journal_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                        </group>
                        <group string="Accounting">
                            <field name="cogs_commission_account_id" readonly="1"/>
                            <field name="commission_move_id" readonly="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Journal Entry" invisible="state != 'posted'">
                            <group>
                                <field name="commission_move_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pos_base_profit_distribution" model="ir.actions.act_window">
        <field name="name">Base Profit Distributions</field>
        <field name="res_model">pos.base.profit.distribution</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No base profit distributions yet
            </p>
            <p>
                Base profit distributions are created when you share base profit from POS orders (TIER 2).
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_pos_base_profit_distribution"
              name="Base Profit Distributions"
              parent="point_of_sale.menu_point_root"
              action="action_pos_base_profit_distribution"
              sequence="21"/>
              
</odoo>
